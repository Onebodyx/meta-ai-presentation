# Шаблон для `.env` в корне проекта с примерами переменных.
# Файл `.env` не коммитится (см. `.gitignore`).

# --- Stockfish (UCI): путь к бинарнику (на вашей машине) ---
# Windows (пример):
# STOCKFISH_PATH=C:\Programs\Stockfish\stockfish-windows-x86-64-avx2.exe
STOCKFISH_PATH=

# --- Cursor Cloud (Cloud Agents API) ---
# Ключ: Cursor Dashboard → Cloud Agents → My Settings → API keys.
# Документация: https://cursor.com/docs/cloud-agent/api/endpoints
# Аутентификация в коде: HTTP Basic (ключ как username, пароль пустой).
# Если CURSOR_CLOUD_BASE_URL пусто, используется https://api.cursor.com
# CURSOR_CLOUD_MODEL: пусто или default — поле model в теле запроса не добавляется.
CURSOR_CLOUD_AGENTS_API_KEY=
CURSOR_CLOUD_BASE_URL=
CURSOR_CLOUD_MODEL=
# Таймаут HTTP в секундах; пусто или неверное значение → 30
CURSOR_CLOUD_TIMEOUT_SEC=300
# URL репозитория GitHub для POST /v0/agents (ключ Cloud Agents должен иметь доступ).
CURSOR_CLOUD_AGENT_REPOSITORY=
# Необязательно: ветка или тег; если пусто — ref в запрос не передаётся.
CURSOR_CLOUD_AGENT_REF=
# Опрос ответа агента при объяснении позиции (секунды). Если MAX_WAIT не задан — как CURSOR_CLOUD_TIMEOUT_SEC.
CURSOR_CLOUD_EXPLAIN_MAX_WAIT_SEC=3000
CURSOR_CLOUD_EXPLAIN_POLL_SEC=2
# Таймаут одного HTTP-запроса (POST/GET) в этом сценарии.
CURSOR_CLOUD_EXPLAIN_HTTP_TIMEOUT_SEC=600
